# Economy-KOL-to-Notion — 环境变量模板
# 复制为 config/.env 并填入真实值。绝不把真密钥提交到 git / 打进公开 image。

# Notion API（写 KOL By Day / By Week / KOL List DB）
# 复用你自己的 Notion integration token；API 版本 2022-06-28。
# GOTCHA：每个 Notion page/DB 必须在 Notion 里把该 integration 加为连接，否则 API 404。
NOTION_TOKEN=

# Exa 搜索（主搜索源，语义+日期过滤，付费）
EXA_API_KEY=

# Tavily 搜索（备用搜索源，付费；曾超额，可留空走 SearXNG 兜底）
TAVILY_API_KEY=

# SearXNG（自托管元搜索，免费兜底）— 由用户维护，默认本地
SEARXNG_URL=http://localhost:8888

# GitHub（dashboard push 用；建议用 gh CLI 凭证而非 PAT）
# GITHUB_PAT=
