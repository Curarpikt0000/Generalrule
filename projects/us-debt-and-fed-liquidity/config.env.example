# ===== 必填 =====
# FRED API：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# ===== 可不填（Hermes 后端已经是 DeepSeek，分析在 Hermes 内部完成）=====
# 仅当你想绕过 Hermes、用 Python 脚本直连 DeepSeek 调试时才需要。
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Token：Hermes 通过 Notion MCP 已配，不用填这里

# ===== 可选 =====
LOG_LEVEL=INFO
TIMEZONE=Asia/Tokyo

# 反爬：Investing.com 用户代理池（可选自定义）
USER_AGENT_POOL=Mozilla/5.0...,...

# 备用源：Wind / 同花顺 / 东方财富（如有 API key）
EASTMONEY_API_KEY=
IFIND_API_KEY=
